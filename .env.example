# Copy this file to ".env" and fill in your key(s). ".env" is gitignored — it will
# NOT be committed. The M5 benchmark (python -m benchmark.run) loads it automatically;
# real exported environment variables take precedence over anything here.

# OpenAI frontier-VLM baseline (python -m benchmark.run --provider openai)
OPENAI_API_KEY=

# Anthropic frontier-VLM baseline (python -m benchmark.run --provider anthropic)
ANTHROPIC_API_KEY=
